# Example environment variables for Mini App production builds
# Copy this file to .env and update the values for your deployment
#
# NOTE: This file is for reference. The actual production build on Render
# passes these values via the buildCommand in render.yaml
#
# Usage:
#   VITE_API_URL=https://your-api-domain.com npm run build

# API URL - the backend API server
VITE_API_URL=https://nexus-4uxn.onrender.com
