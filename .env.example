# Database Configuration
# Local PostgreSQL:
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@localhost:5432/nexus
# Supabase Transaction Pooler (recommended for production):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supabase Direct (for migrations only):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Database Pool Settings (important for Supabase/managed databases)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=your_webhook_secret_here

# Security
# ENCRYPTION_KEY: Used for encrypting sensitive data (bot tokens, etc.)
# Must be a valid Fernet key. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# JWT_SECRET: Used for signing JWT tokens for Mini App authentication
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# AI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Environment
ENVIRONMENT=development

# Development Settings
# WARNING: Only enable in development! Disables Telegram initData hash validation
# for testing the Mini App outside of Telegram (e.g., in a browser)
DISABLE_AUTH_VALIDATION=false

# Mini App Configuration
# Local Development:
# VITE_API_URL=http://localhost:8000
# MINI_APP_URL=http://localhost:3000
# Production (Render):
VITE_API_URL=https://nexus-4uxn.onrender.com
MINI_APP_URL=https://nexus-4uxn.onrender.com

# Optional Integrations
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# Owner & Support Configuration
# Comma-separated list of Telegram user IDs with special permissions
# OWNER_IDS: Full admin access across all groups, can access system functions
# SUPPORT_IDS: Support staff access for helping users
# Example: OWNER_IDS=123456789,987654321
OWNER_IDS=
SUPPORT_IDS=

# Bot Configuration
# The bot username for "Add to Group" links (without @)
# Example: BOT_USERNAME=nexusbot
BOT_USERNAME=nexusbot
